# Merit Aktiva API credentials.
#
# Generate these inside Merit Aktiva:
#   Settings (Seadistused) -> Company data (Ettevotte andmed) -> API settings (API seadistus)
#   -> enter a comment and click "Koosta voti" (Generate key).
# Requires a Pro or Premium Merit Aktiva license.
#
# Copy this file to .env and fill in your own values. NEVER commit the real .env.

# API ID — the GUID shown in the API settings table.
MERIT_API_ID=your-api-id-here

# API Key — the base64 secret paired with the API ID. Treat like a password.
MERIT_API_KEY=your-api-key-here

# Account localization: "ee" (Estonia, aktiva.merit.ee) or "pl" (Poland, program.360ksiegowosc.pl).
# Default: ee
MERIT_LOCALIZATION=ee

# Default API version for endpoints that exist in both v1 and v2: "v1" or "v2".
# Default: v1
MERIT_API_VERSION=v1

# --- References directory (optional) ---
# Base directory for elnora-merit's per-machine reference/config files: the Stripe
# map, the reconcile idempotency ledger, resolver overrides, the äriregister cache,
# and the synced company-profile.json. Default: ~/.config/elnora-merit
# Set this to share ONE references home between the CLI and an agent (e.g. point it
# at a folder in your private workspace). The credential .env stays anchored at the
# home default for safety; if you set this AND keep a .env inside it, that .env is
# also read (at higher precedence). Generate the profile with `elnora-merit profile sync`.
# MERIT_REFERENCES_DIR=/path/to/your/references/elnora-merit

# --- Merit Palk payroll (optional; only needed for the `elnora-merit palk` commands) ---
# Palk is a SEPARATE Merit product with its own credentials and host
# (palk.merit.ee, Estonia-only, v1 API). Generate these inside Merit Palk:
#   Settings -> API Settings -> New API key. Requires a Merit Palk PRO license.
MERIT_PALK_API_ID=your-palk-api-id-here
MERIT_PALK_API_KEY=your-palk-api-key-here

# --- Stripe reconcile (optional; only needed for `elnora-merit reconcile`) ---
# Stripe secret/restricted key for the account whose payouts you book into Merit.
# Use the LIVE key for the correct account (a read-only restricted key is enough).
# Treat like a password. The reconcile account/VAT mapping lives in stripe-map.json,
# not here (see stripe-map.example.json and `elnora-merit reconcile init`).
STRIPE_API_KEY=your-stripe-secret-key-here

# --- Estonian Business Register live XML API (optional; for `elnora-merit ariregister`) ---
# Credentials for the FREE äriregister XML services (ettevotjaRekvisiidid_v1 requisite
# lookup). Create an XML-authorised user in the e-äriregister portal
# (https://ariregister.rik.ee -> Haldus -> Kasutajate haldamine) and use that account's
# username + password. The e-invoice-check service (earveRegistriParing_v1) needs none.
# Treat the password like a secret.
ARIREG_XML_USER=your-ariregister-username
ARIREG_XML_PASSWORD=your-ariregister-password
# Endpoint: leave unset for production. Set ARIREG_XML_ENV=test for the demo endpoint,
# or ARIREG_XML_URL to override the full URL.
# ARIREG_XML_ENV=test

# --- Document sync (optional; only for `elnora-merit documents run`) ---
# Slack-compatible incoming-webhook URL for the missing-document digest. Slack,
# Mattermost, and Discord (…/slack) all accept the { "text": "…" } POST it sends.
# Treat like a password. Sources, thresholds, and staging live in docsync.json
# (see docsync.example.json), not here. Leave unset to just print the digest.
# MERIT_DOCSYNC_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
